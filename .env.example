# Cloudflare Tunnel
TUNNEL_TOKEN=your_cloudflare_tunnel_token

# PostgreSQL — matches docker-compose service name
DATABASE_URL=postgresql://rehorse:rehorse_password@postgres:5432/rehorse

# NextAuth — MUST be your exact public Cloudflare URL (no trailing slash)
NEXTAUTH_URL=https://rehorse.icecoldlime.com
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_secure_random_string
# Admin-only API/action secret. Generate with: openssl rand -base64 32
ADMIN_SECRET=replace_with_secure_random_string

# Postgres credentials (used by docker-compose postgres service)
POSTGRES_DB=rehorse
POSTGRES_USER=rehorse
POSTGRES_PASSWORD=rehorse_password

# ── Spotify (opcional — fallback para iTunes se não configurado) ──────────────
# Crie em: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Push Notifications (Web Push / VAPID) ────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
VAPID_EMAIL=noreply@rehorse.app
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# This must be the same as VAPID_PUBLIC_KEY — exposed to the browser
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Secret token to protect /api/cron/rehearsal-reminder
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ── LOCAL ONLY (for running the migration script on your machine) ──────────────
# DATABASE_URL_LOCAL=postgresql://rehorse:rehorse_password@localhost:5434/rehorse
